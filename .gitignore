.DS_Store
*.swp
*.swo
*~

# kerf working state.
# We TRACK the design-reasoning knowledge (works/ + the standard-bead process
# template + project metadata) so it survives a machine loss and merges to main
# via the per-work `kerf/<codename>` branch convention (see
# docs/components/internal/kerf.md §"Artifact durability & commit convention").
# We still IGNORE: the large local caches (diagnostics-cache.json ~56MB,
# sync-cache.json) and kerf's internal per-edit .history/ snapshot trail (git is
# our history now — tracking it would bloat the repo with thousands of dup files).
.kerf/*
!.kerf/project-identifier
!.kerf/jigs/
!.kerf/jigs/*.md
!.kerf/works/
!.kerf/standard-bead-dot/
!.kerf/config.yaml
!.kerf/project.yaml
# Re-ignore caches and history-snapshots inside the now-tracked subtrees.
.kerf/works/**/.history/
.kerf/**/*-cache.json

# Beads task ledger — ignore SQLite DB / WAL / locks / backups; track only test fixtures
# issues.jsonl is gitignored: `br sync --flush-only` writes it continuously, so tracking it
# creates a perpetually dirty working tree that triggers implementer_escaped_worktree false-fails
# when the daemon runs. Same fix applied to HANDOFF.md (15382e4f). Refs: hk-yru
.beads/*
!.beads/queue-test-fixtures/

# Beads ledger backup directories created by ledger-archive-runbook.md rollback step
.beads.bak*/

# Go build outputs and test artifacts (build-practices.md §Git hygiene)
/bin/
/dist/
/coverage.out
*.test

# Twin-binary build artifacts (SH-009 in-tree default dir; binaries are not committed)
/twins/*
!/twins/.gitkeep

# Harmonik runtime state (context/ is committed as tier-3/tier-2 bootstrap; see leanfleet D5)
# crew/missions/ is committed so mission self-terminate clauses are reviewable in git (hk-ev9e)
/.harmonik/*
!/.harmonik/context
!/.harmonik/crew
!/.harmonik/crew/missions
!/.harmonik/release-ledger.json
# Daemon-written task files in worktrees (hk-ynn8u)
.harmonik/agent-task*

# Dev tools installed locally (subsystem-organization.md §Decisions #10)
/.tools/

# Orchestrator-spawned implementer worktrees (HANDOFF v23 friction note)
/.claude/worktrees/

# Stray sub-agent scratch dirs
/.claire/

# bv (beads viewer) local config and caches
.bv/
/harmonik
/harmonik-twin-claude

# Pi extension node_modules (npm install output; lockfile is committed)
.pi/extensions/*/node_modules/

# Scoped credential file read by `harmonik supervise start` (CI-006, CI-007).
# MUST NOT be committed — contains ANTHROPIC_API_KEY in plaintext.
.env
.env.*
*.env
.env.*.local
*.env.txt
edited.env.txt

# Per-thread session handoffs (operator/agent working artifacts). The canonical
# HANDOFF.md stays tracked; per-thread HANDOFF-<name>.md are scratch and MUST be
# ignored — otherwise the daemon's worktree-escape detector false-positives on
# them as main-repo contamination and fails dispatched beads (hk-veoht follow-up).
HANDOFF-*.md

# Claude Code session scheduler lock
.claude/scheduled_tasks.lock

# Claude Code PID file written to repo root by `claude --dangerously-skip-permissions` runs
.claude-pid

# Scratch/exploratory docs not intended for permanent tracking
docs/qa-scratch/

# Local AI-tool search indexes / caches — kept on disk for the tools that use
# them, but regenerable and never committed (.ee = ee search index incl. binary
# tantivy files; .cass = CASS cache; .codex = local codex rules/cache).
.ee/
.cass/
.codex/

# Python bytecode
__pycache__/
*.pyc

HANDOFF.md
