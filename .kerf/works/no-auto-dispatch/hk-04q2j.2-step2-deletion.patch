-}
-
-func (s *showBeadRetryLedger) ClaimBead(_ context.Context, _ string, _ brcli.TimeoutConfig, _ core.RunID, _ core.TransitionID, id core.BeadID) error {
-	if id == s.goodBead {
-		s.goodClaimed.Store(true)
