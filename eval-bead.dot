// eval-bead.dot — lightweight eval-task workflow (hk-olzgq / hk-eval-harness-dot-flbj3)
//
// Routes eval coding-task beads (codename:eval) away from the project-level
// workflow.dot (sonnet-triple-review) whose 3-reviewer cascade times out on the
// small diffs produced by eval tasks. Implements the EH2 spec from
// plans/2026-07-02-eval-harness/DESIGN.md §1.2.
//
// Topology:
//   start → implement → grade → judge (non-gating) → close-pass
//                            ↓ fail
//                          close-fail
//
// Design choices (per DESIGN.md §1.2):
//   - No fix-loop: eval measures one-shot capability; a loop contaminates the signal.
//   - grade is deterministic (shell): exit 0 = pass, exit ≠ 0 = fail.
//   - judge uses rubric-v1 (Q1-Q5; see docs/eval-review-schema-v1.md) on a fixed
//     model (claude-opus-4-8, constant across all models-under-test for comparability).
//     Non-gating: always routes to close-pass so a quality score never blocks landing.
//     Its outcome_emitted is the signal the eval collector (EH1) reads as pass=true.
//   - harness selection: per-bead harness:pi label (or default) is honoured for the
//     implement node — eval-bead.dot does not override harness.

digraph "eval-bead" {
    // ─── Graph-level attributes ──────────────────────────────────────────────
    schema_version="1";
    version="1.0";
    workflow_id="eval-bead";
    start_node="start";
    terminal_node_ids="close-pass,close-fail";
    context_keys="bead_id";

    // ─── Nodes ───────────────────────────────────────────────────────────────
    start [
        type="non-agentic",
        handler_ref="noop",
        idempotency_class="idempotent",
        role="entry"
    ];

    // implement: model-under-test (harness selected from bead label, e.g. harness:pi).
    // One-shot: no fix-loop after grade failure.
    implement [
        type="agentic",
        agent_type="implementer",
        handler_ref="claude-implementer",
        idempotency_class="non-idempotent",
        role="implement the eval task; commit required. Create the solution file(s) as described in the task. COMMIT the solution AND any provided test files. Do NOT modify or delete pre-committed test files."
    ];

    // grade: deterministic shell check. Runs the task's own go test.
    // exit 0 = pass → judge; exit ≠ 0 = fail → close-fail (no fix-loop).
    grade [
        type="non-agentic",
        handler_ref="shell",
        idempotency_class="idempotent",
        tool_command="bash scripts/eval-grade.sh",
        timeout="120",
        role="deterministic grade: run the task's go test; exit 0 = pass"
    ];

    // judge: rubric-v1 quality scorer (non-gating). Fixed model=claude-opus-4-8 held
    // constant across all models-under-test so the quality axis is comparable
    // (02-quality-assessment.md §2). Writes .harmonik/review.json with Q1-Q5 scores
    // per docs/eval-review-schema-v1.md. Its outcome_emitted is what the eval collector
    // (EH1) reads as pass=true. Never loops back: every verdict routes to close-pass.
    judge [
        type="agentic",
        agent_type="reviewer",
        handler_ref="claude-reviewer",
        idempotency_class="idempotent",
        model="claude-opus-4-8",
        effort="low",
        role="eval quality judge (non-gating, rubric-v1). Score ONE candidate solution to a programming task. You do NOT know and MUST NOT guess which model or system produced it — judge ONLY the code in front of you. Verbosity is NOT quality; a shorter correct solution outscores a longer one.\n\nREAD before scoring:\n- TASK SPEC: read the Task Description in your agent-task.md.\n- GRADE RESULT: deterministic test suite PASSED (you run only when grade exit=0).\n- OBJECTIVE METRICS: read .harmonik/metrics.json if present (gofmt/vet/gocyclo, TODO count, diff line count vs budget, expected_big_o, unused-symbol scan). If absent, note metrics unavailable in evidence.\n- DIFF: run git show HEAD to get the implementer's commit as a unified patch.\n\nSCORE each dimension 1-5 (integers only). For EACH cite the specific line(s) or metric.\nQ1 correctness-beyond-tests: right on cases the shipped test does NOT cover (boundaries/nil/overflow/error paths/concurrency). Try to construct a failing input; if you cannot, score toward 5. Q1 is ONLY scored when grade=PASS — which it is.\nQ2 completeness: whole task done, no stub/TODO/FIXME/partial.\nQ3 code-quality/idiom: idiomatic and readable; metrics are ground truth for fmt/vet/complexity — judge the subjective remainder.\nQ4 efficiency: complexity class appropriate to the task (see expected_big_o in metrics); no redundant passes or obvious allocs.\nQ5 no-dead-code/no-over-reach: minimal — no unused symbols, no unrequested abstraction/config/features. Code that adds machinery the task did NOT ask for is PENALIZED even if it compiles.\n\nWrite ONLY the following JSON to .harmonik/review.json:\n{\"schema_version\":1,\"verdict\":\"APPROVE\",\"scores\":{\"Q1\":n,\"Q2\":n,\"Q3\":n,\"Q4\":n,\"Q5\":n},\"evidence\":{\"Q1\":\"cite lines/metrics\",\"Q2\":\"cite\",\"Q3\":\"cite\",\"Q4\":\"cite\",\"Q5\":\"cite\"},\"notes\":\"1-3 sentences; do not speculate about which model or system produced this\"}\n\nverdict is ALWAYS APPROVE — this judge NEVER gates the eval. Do NOT request changes or loop back."
    ];

    "close-pass" [
        type="non-agentic",
        handler_ref="noop",
        idempotency_class="idempotent",
        role="grade PASS — solution passed the deterministic check"
    ];

    "close-fail" [
        type="non-agentic",
        handler_ref="noop",
        idempotency_class="idempotent",
        role="grade FAIL — solution did not pass the deterministic check (no fix-loop)"
    ];

    // ─── Edges ───────────────────────────────────────────────────────────────
    start -> implement;
    implement -> grade;

    // grade SUCCESS → judge (quality score, then unconditional close-pass).
    grade -> judge [
        condition="outcome.status == 'SUCCESS'"
    ];
    // grade FAIL → close-fail immediately (no fix-loop per eval design).
    grade -> "close-fail" [
        condition="outcome.status == 'FAIL'"
    ];
    // grade fallback (WG-011: mandatory unconditional fallback must appear last).
    grade -> "close-fail";

    // judge is non-gating: ALL verdict paths → close-pass.
    judge -> "close-pass" [
        condition="outcome.preferred_label == 'APPROVE'"
    ];
    judge -> "close-pass" [
        condition="outcome.preferred_label == 'REQUEST_CHANGES'"
    ];
    judge -> "close-pass" [
        condition="outcome.preferred_label == 'BLOCK'"
    ];
    // Unconditional fallback — REQUIRED by WG-011.
    judge -> "close-pass";
}
