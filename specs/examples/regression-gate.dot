// regression-gate.dot — reproduce-before-fix workflow with regression suite (v1)
//
// Encodes the reproduce-before-fix discipline as a graph: the reproduce node's
// FAIL is the *desired* forward path (the bug must reproduce before we trust a
// fix), then the agent fixes it, then a full regression suite catches both
// "fix didn't take" and "fix broke something else."
//
// Topology:
//   start
//   → reproduce (tool: go test ./scenarios -run TargetBug)
//     FAIL    → fix_bug          (bug confirmed present → proceed to fix)
//     SUCCESS → cannot_reproduce → close-needs-attention  (cannot reproduce)
//     fallback → close-needs-attention  (infra failure during probe)
//   → fix_bug (agent: fix the bug; commit required)
//   → regression_suite (tool: go test ./scenarios/... timeout=900s)
//     SUCCESS              → close
//     FAIL+deterministic   → fix_bug (capped at 3 — fix didn't take or regression)
//     fallback             → close-needs-attention (transient / structural / budget)
//
// Key design note: reproduce exits non-zero (FAIL) to confirm the bug is
// present — that is the desired forward path.  A zero exit (SUCCESS) means the
// test passed, i.e. the bug is absent, which is the exceptional "cannot
// reproduce" branch that routes to triage.
//
// Spec refs:
//   - docs/sdlc-workflow-corpus.md §16 (regression-gate topology)
//   - specs/workflow-graph.md §4 WG-039 — tool_command / shell handler
//   - specs/execution-model.md §II.7 EM-057 item 7 — exit-code → outcome
//   - specs/execution-model.md §II.8 EM-058 — non-agentic row + sub-note
//   - specs/handler-contract.md §III.1 HC-063 — in-process shell handler
//   - specs/workflow-graph.md §5 WG-011 — unconditional-edge fallback invariant
//   - specs/workflow-graph.md §6 WG-013 — v1 edge-condition dialect (== and && only)
//   - specs/workflow-graph.md §6 WG-028 — traversal_cap
//   - specs/workflow-graph.md §8 WG-021..WG-023 — terminal-node declaration
//   - specs/workflow-graph.md §9 WG-027 — start_node attribute
//   - specs/handler-contract.md §4.1 HC-001 — handler_ref required on every node

digraph "regression-gate" {
    // ─── Graph-level attributes ───────────────────────────────────────────────
    schema_version="1";
    version="1.0";
    workflow_id="regression-gate";
    start_node="start";
    terminal_node_ids="close,close-needs-attention";

    // ─── Nodes ────────────────────────────────────────────────────────────────

    // start: workflow entry point.
    start [
        type="non-agentic",
        handler_ref="noop",
        idempotency_class="idempotent",
        role="entry"
    ];

    // reproduce: confirm the bug is present before investing in a fix.
    // Runs the targeted regression; a non-zero exit (FAIL) means the bug
    // reproduces — that is the desired forward path to fix_bug.
    // A zero exit (SUCCESS) means the bug is absent → cannot_reproduce.
    reproduce [
        type="non-agentic",
        handler_ref="shell",
        idempotency_class="idempotent",
        tool_command="go test ./scenarios -run TargetBug",
        timeout="300",
        role="confirm the bug reproduces — FAIL is the forward path"
    ];

    // fix_bug: agent patches the root cause; HEAD must advance (commit required).
    fix_bug [
        type="agentic",
        agent_type="implementer",
        handler_ref="claude-implementer",
        idempotency_class="non-idempotent",
        role="fix the bug; commit required"
    ];

    // regression_suite: full scenario suite run after the fix attempt.
    // Exit 0 (SUCCESS) → fix holds, no regressions → close.
    // Non-zero + deterministic failure_class → fix didn't take or introduced a
    // regression → loop back to fix_bug (capped at 3 traversals).
    // Any other outcome (transient infra, budget, etc.) → close-needs-attention.
    regression_suite [
        type="non-agentic",
        handler_ref="shell",
        idempotency_class="idempotent",
        tool_command="go test ./scenarios/...",
        timeout="900",
        role="full regression suite — exit 0 = green, non-zero = regression or infra failure"
    ];

    // cannot_reproduce: the bug probe exited 0 — no evidence of the bug.
    // Routes to close-needs-attention for operator triage.
    cannot_reproduce [
        type="non-agentic",
        handler_ref="noop",
        idempotency_class="idempotent",
        role="bug did not reproduce — needs operator triage"
    ];

    // close: fix verified — regression suite is green.
    close [
        type="non-agentic",
        handler_ref="noop",
        idempotency_class="idempotent",
        role="fix holds, suite green"
    ];

    // close-needs-attention: cap-hit / regression / cannot-reproduce / infra failure.
    "close-needs-attention" [
        type="non-agentic",
        handler_ref="noop",
        idempotency_class="idempotent",
        role="cap-hit / regression / cannot-reproduce / infra failure"
    ];

    // ─── Edges ────────────────────────────────────────────────────────────────

    start -> reproduce;

    // reproduce: non-zero exit (FAIL) = bug confirmed present → fix it.
    reproduce -> fix_bug [
        condition="outcome.status == 'FAIL'"
    ];
    // reproduce: zero exit (SUCCESS) = test passed, bug absent → cannot reproduce.
    reproduce -> cannot_reproduce [
        condition="outcome.status == 'SUCCESS'"
    ];
    // Unconditional fallback (WG-011): unexpected outcome (infra failure) → triage.
    reproduce -> "close-needs-attention";

    // cannot_reproduce is a pure routing node → triage.
    cannot_reproduce -> "close-needs-attention";

    // fix_bug always advances to regression_suite.
    fix_bug -> regression_suite;

    // regression_suite: green → close.
    regression_suite -> close [
        condition="outcome.status == 'SUCCESS'"
    ];
    // Fix didn't take or introduced a regression: loop back to fix_bug (capped).
    // The && conjunction (D5 v1 dialect) requires BOTH status=FAIL AND
    // failure_class=deterministic (compilation error, test assertion failure).
    regression_suite -> fix_bug [
        condition="outcome.status == 'FAIL' && outcome.failure_class == 'deterministic'",
        traversal_cap="3"
    ];
    // Unconditional fallback (WG-011): transient / structural / budget failures → triage.
    regression_suite -> "close-needs-attention";
}
