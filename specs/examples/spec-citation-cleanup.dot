// spec-citation-cleanup.dot вЂ” content gate в†’ citation fixerв†”verifier sub-loop (v1)
//
// Pinned by:
//   - docs/sdlc-workflow-corpus.md В§8 (spec-citation-cleanup, spec authoring topology)
//   - specs/workflow-graph.md В§5 WG-010 (5-step edge-selection cascade)
//   - specs/workflow-graph.md В§5 WG-011 (unconditional-edge fallback invariant)
//   - specs/workflow-graph.md В§8 WG-021..WG-023 (terminal-node declaration)
//   - specs/workflow-graph.md В§10 WG-028 (cycle bounding / traversal_cap)
//   - specs/execution-model.md В§4.3 EM-015d (review-loop topology)
//   - specs/execution-model.md В§4.3 EM-015e (no-progress / cap-hit vocabulary)
//   - specs/execution-model.md В§4.9 EM-043 (traversal-cap enforcement)
//
// Two-phase structure:
//   Phase 1 вЂ” Content gate: content_review checks spec BODY only (ignores citation
//             formatting). APPROVE advances to the citation sub-loop. REQUEST_CHANGES
//             loops back to author. BLOCK or unrecognized label terminates.
//   Phase 2 вЂ” Citation sub-loop: citation_fixer repairs every stale cross-ref; commit
//             required (outcome.status == 'SUCCESS') to hand off to citation_verify.
//             citation_verify approves ONLY when all citations are live. REQUEST_CHANGES
//             loops back to citation_fixer. BLOCK or unrecognized label terminates.
//
// Demonstrates:
//   - Role-differentiation via node `role` briefs (content reviewer vs. citation verifier
//     are distinct postures running on the same reviewer handler).
//   - Commit-gated (outcome.status == 'SUCCESS') authorв†’reviewer handoff between phases.
//   - Tight fixerв†”verifier sub-loop with independent traversal_cap.
//   - Also covers the spec-drift-rereview pattern: a reconcileв†”re-review loop is the
//     same shape with different role briefs.
//
// Walk paths:
//   Happy path:     start в†’ author в†’ content_review(APPROVE) в†’ citation_fixer(SUCCESS)
//                   в†’ citation_verify(APPROVE) в†’ close
//   Content loop:   content_review(RC) в†’ author в†’ content_review в†’ ... (cap=3)
//   Citation loop:  citation_verify(RC) в†’ citation_fixer(SUCCESS) в†’ citation_verify в†’ ... (cap=3)
//   BLOCK:          content_review(BLOCK) or citation_verify(BLOCK) в†’ close-needs-attention
//   Fixer fail:     citation_fixer non-SUCCESS в†’ close-needs-attention (unconditional fallback)
//   Fallback:       unrecognized label on any reviewer в†’ unconditional fallback в†’ close-needs-attention
//
// Design notes:
//   - All edge conditions use the D5 v1 dialect (equality + && only). NO `<`/`>`.
//   - traversal_cap="3" on every back-edge enforces the EM-015e/WG-028 iteration limit.
//   - Terminal IDs use the hyphenated form (close-needs-attention) per C1 convention.
//   - Unconditional fallback edges appear LAST per WG-011 (D-edge-cascade-invariant).
//   - citation_fixer uses outcome.status == 'SUCCESS' as the forward gate (commit-gated
//     handoff); failure falls through to the unconditional fallback в†’ close-needs-attention.

digraph "spec-citation-cleanup" {
    // в”Ђв”Ђв”Ђ Graph-level attributes в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    schema_version="1";
    version="1.0";
    workflow_id="spec-citation-cleanup";
    start_node="start";
    terminal_node_ids="close,close-needs-attention";
    context_keys="bead_id";

    // в”Ђв”Ђв”Ђ Nodes в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    // start: workflow entry point.
    start [
        type="non-agentic",
        handler_ref="noop",
        idempotency_class="idempotent",
        role="entry"
    ];

    // author: drafts or revises the spec. On re-entry (after content_review
    // REQUEST_CHANGES), addresses the content feedback from content_review.
    author [
        type="agentic",
        agent_type="implementer",
        handler_ref="claude-implementer",
        idempotency_class="non-idempotent",
        role="draft/revise spec content"
    ];

    // content_review: reviews ONLY spec body content вЂ” structure, accuracy,
    // completeness. Explicitly ignores citation formatting. APPROVE signals
    // content is clean and the citation sub-loop may begin.
    content_review [
        type="agentic",
        agent_type="reviewer",
        handler_ref="claude-reviewer",
        idempotency_class="idempotent",
        role="review spec CONTENT only (ignore citation formatting)"
    ];

    // citation_fixer: repair pass вЂ” fixes every stale cross-reference: section
    // anchors, sibling-spec citations, bead refs. Must commit (SUCCESS) to
    // advance to citation_verify.
    citation_fixer [
        type="agentic",
        agent_type="implementer",
        handler_ref="claude-implementer",
        idempotency_class="non-idempotent",
        role="fix every stale cross-ref: section anchors, sibling-spec citations, bead refs"
    ];

    // citation_verify: verifies EVERY cross-reference resolves. APPROVEs only
    // when all citations are live; REQUEST_CHANGES loops back to citation_fixer.
    citation_verify [
        type="agentic",
        agent_type="reviewer",
        handler_ref="claude-reviewer",
        idempotency_class="idempotent",
        role="verify EVERY cross-reference resolves; APPROVE only if all citations are live"
    ];

    // close: terminal node вЂ” content clean and all citations verified live.
    close [
        type="non-agentic",
        handler_ref="noop",
        idempotency_class="idempotent",
        role="content + citations clean"
    ];

    // close-needs-attention: terminal node for BLOCK, cap-hit, fixer failure,
    // and unconditional-fallback paths. Operator attention required.
    "close-needs-attention" [
        type="non-agentic",
        handler_ref="noop",
        idempotency_class="idempotent",
        role="BLOCK / cap-hit / fixer failure вЂ” needs operator attention"
    ];

    // в”Ђв”Ђв”Ђ Edges в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    // (1) Entry edge вЂ” unconditional.
    start -> author;

    // (2) Author hands off to content reviewer вЂ” unconditional.
    author -> content_review;

    // (3a) content_review APPROVE в†’ advance to citation_fixer (Phase 2 begins).
    content_review -> citation_fixer [
        condition="outcome.preferred_label == 'APPROVE'"
    ];

    // (3b) content_review REQUEST_CHANGES в†’ loop back to author (capped at 3
    // per EM-015e/WG-028).
    content_review -> author [
        condition="outcome.preferred_label == 'REQUEST_CHANGES'",
        traversal_cap="3"
    ];

    // (3c) content_review BLOCK в†’ close-needs-attention.
    content_review -> "close-needs-attention" [
        condition="outcome.preferred_label == 'BLOCK'"
    ];

    // (3d) Unconditional fallback вЂ” catches unrecognized or absent preferred_label.
    // Must appear last per WG-011.
    content_review -> "close-needs-attention";

    // (4a) citation_fixer SUCCESS в†’ advance to citation_verify (commit-gated handoff).
    // outcome.status gate: only a committed fix earns entry to citation_verify.
    citation_fixer -> citation_verify [
        condition="outcome.status == 'SUCCESS'"
    ];

    // (4b) citation_fixer non-SUCCESS в†’ close-needs-attention (unconditional fallback).
    citation_fixer -> "close-needs-attention";

    // (5a) citation_verify APPROVE в†’ close. All citations live.
    citation_verify -> close [
        condition="outcome.preferred_label == 'APPROVE'"
    ];

    // (5b) citation_verify REQUEST_CHANGES в†’ loop back to citation_fixer (capped
    // at 3 per EM-015e/WG-028). Tight fixerв†”verifier sub-loop.
    citation_verify -> citation_fixer [
        condition="outcome.preferred_label == 'REQUEST_CHANGES'",
        traversal_cap="3"
    ];

    // (5c) citation_verify BLOCK в†’ close-needs-attention.
    citation_verify -> "close-needs-attention" [
        condition="outcome.preferred_label == 'BLOCK'"
    ];

    // (5d) Unconditional fallback. Must appear last per WG-011.
    citation_verify -> "close-needs-attention";
}
